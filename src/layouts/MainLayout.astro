---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import ConversionAssist from '../components/ConversionAssist.astro';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  keywords?: string;
  siteName?: string;
  schemas?: Record<string, unknown>[];
  preloadImages?: { href: string; type?: string }[];
  showFooter?: boolean;
  showConversionAssist?: boolean;
}

const {
  title = 'Femme Nest Hospital | Best Maternity Centre & Pregnancy Care in East Delhi',
  description = 'Femme Nest Hospital offers expert maternity, pregnancy, gynecology, and fertility care in East Delhi with compassionate doctors and modern facilities.',
  canonical = 'https://www.femmenest.com/',
  ogImage = '/images/fn/ivf_2.png',
  keywords = 'Femme Nest Hospital, maternity hospital East Delhi, best maternity centre East Delhi, pregnancy care East Delhi, gynecology clinic East Delhi, fertility clinic East Delhi',
  siteName = 'Femme Nest Hospital',
  schemas = [],
  preloadImages = [],
  showFooter = true,
  showConversionAssist = true,
} = Astro.props;

const localBusinessSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': ['Hospital', 'MedicalClinic', 'LocalBusiness'],
  name: 'Femme Nest Hospital',
  description: 'Maternity and pregnancy care hospital in East Delhi offering gynecology, fertility care, and women\'s wellness services.',
  url: 'https://www.femmenest.com',
  telephone: '+91-9800000000',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Femme Nest Hospital, East Delhi',
    addressLocality: 'East Delhi',
    addressRegion: 'Delhi',
    postalCode: '110001',
    addressCountry: 'IN',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '28.6139',
    longitude: '77.2090',
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '09:00',
      closes: '19:00',
    },
  ],
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '324',
  },
  medicalSpecialty: 'Maternity Care, Pregnancy Care, Gynecology, Fertility Care',
};

const mergedSchemas = [localBusinessSchema, ...schemas];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#E84C8A" />
  <link rel="icon" href="/logo-hospital-favicon.png" type="image/png" />
  <link rel="shortcut icon" href="/logo-hospital-favicon.png" type="image/png" />
  <link rel="apple-touch-icon" href="/logo-hospital-favicon.png" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <link rel="canonical" href={canonical} />
  {preloadImages.map((image) => (
    <link rel="preload" as="image" href={image.href} type={image.type} />
  ))}

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="en_IN" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&family=Outfit:wght@200;300;400;500;600&display=swap"
    rel="stylesheet"
  />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

  {mergedSchemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>
<body>
  <slot />
  {showConversionAssist && <ConversionAssist />}
  {showFooter && <Footer />}

  <script>
    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((el) => {
        if (el.isIntersecting) {
          el.target.classList.add('visible');
          observer.unobserve(el.target);
        }
      });
    }, { threshold: 0.1 });
    revealEls.forEach((el) => observer.observe(el));
  </script>
</body>
</html>
