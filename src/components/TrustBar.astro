---
// TrustBar.astro - Trust indicators marquee strip
---

<section class="trust-bar" aria-label="Trust indicators">
  <div class="trust-track" role="list" aria-label="Clinic accreditations and achievements">
    <div class="trust-content">
      <div class="trust-item" role="listitem">
        <i class="fa-solid fa-baby" aria-hidden="true"></i>
        <span>2000+ Successful IVF Cases</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
      <div class="trust-item" role="listitem">
        <i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i>
        <span>20+ Years Experience</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
      <div class="trust-item" role="listitem">
        <i class="fa-solid fa-heart" aria-hidden="true"></i>
        <span>5.0 Patient Love Score</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
      <div class="trust-item" role="listitem">
        <i class="fa-solid fa-shield-halved" aria-hidden="true"></i>
        <span>NABH Accredited</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
      <div class="trust-item" role="listitem">
        <i class="fa-solid fa-percent" aria-hidden="true"></i>
        <span>75% IVF Success Rate</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
      <div class="trust-item" role="listitem">
        <i class="fa-solid fa-location-dot" aria-hidden="true"></i>
        <span>Delhi's Trusted Fertility Centre</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>

      <div class="trust-item" role="listitem" aria-hidden="true">
        <i class="fa-solid fa-baby"></i>
        <span>2000+ Successful IVF Cases</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
      <div class="trust-item" role="listitem" aria-hidden="true">
        <i class="fa-solid fa-clock-rotate-left"></i>
        <span>20+ Years Experience</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
      <div class="trust-item" role="listitem" aria-hidden="true">
        <i class="fa-solid fa-heart"></i>
        <span>5.0 Patient Love Score</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
      <div class="trust-item" role="listitem" aria-hidden="true">
        <i class="fa-solid fa-shield-halved"></i>
        <span>NABH Accredited</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
      <div class="trust-item" role="listitem" aria-hidden="true">
        <i class="fa-solid fa-percent"></i>
        <span>75% IVF Success Rate</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
      <div class="trust-item" role="listitem" aria-hidden="true">
        <i class="fa-solid fa-location-dot"></i>
        <span>Delhi's Trusted Fertility Centre</span>
      </div>
      <div class="trust-dot" aria-hidden="true">Ģ</div>
    </div>
  </div>
</section>

<style>
  .trust-bar {
    background: var(--midnight);
    padding: 18px 0;
    overflow: hidden;
    position: relative;
  }

  .trust-bar::before,
  .trust-bar::after {
    content: '';
    position: absolute;
    top: 0;
    width: 90px;
    height: 100%;
    z-index: 2;
    pointer-events: none;
  }

  .trust-bar::before {
    left: 0;
    background: linear-gradient(90deg, var(--midnight), transparent);
  }

  .trust-bar::after {
    right: 0;
    background: linear-gradient(-90deg, var(--midnight), transparent);
  }

  .trust-track { overflow: hidden; }

  .trust-content {
    display: flex;
    align-items: center;
    white-space: nowrap;
    animation: marquee 36s linear infinite;
    width: max-content;
  }

  .trust-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 0 30px;
  }

  .trust-item i {
    color: #ff6cae;
    font-size: 0.92rem;
    flex-shrink: 0;
  }

  .trust-item span {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 400;
    color: var(--champagne);
    letter-spacing: 0.06em;
  }

  .trust-dot {
    color: #f7a088;
    font-size: 0.8rem;
    opacity: 0.8;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-content { animation-play-state: paused; }
  }

  @media (max-width: 600px) {
    .trust-item span { font-size: 0.88rem; }
    .trust-item { padding: 0 22px; }
  }
</style>
