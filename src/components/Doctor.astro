---
// Doctor.astro — High-trust doctor section on midnight background
---

<section class="doctor" id="about" aria-labelledby="doctor-heading">
  <div class="doctor-inner">
    <!-- Image -->
    <div class="doctor-image reveal">
      <div class="doctor-img-wrapper">
        <div class="doctor-img-placeholder" aria-label="Doctor photograph placeholder">
          <img
            src="/images/hero/priya-singh-doctor.png"
            alt="Dr. Priya Sharma"
            class="doctor-photo"
            loading="lazy"
          />
        </div>
        <div class="doctor-exp-badge" aria-label="20 plus years experience">
          <span class="number">20+</span>
          <span class="label">Years</span>
        </div>
      </div>
    </div>

    <!-- Info -->
    <div class="doctor-info reveal">
      <span class="section-tag">Our Expert</span>
      <h2 id="doctor-heading">
        Dr. <em>Priya Sharma</em>
      </h2>
      <p class="doctor-title">MBBS · MD (Obs & Gyn) · Fellowship in Reproductive Medicine</p>

      <p>
        With over two decades of experience in reproductive medicine, Dr. Priya Sharma is Delhi's most trusted name in IVF and fertility care. She has helped over 2,000 families achieve the joy of parenthood through compassionate, evidence-based treatment.
      </p>
      <p>
        Specializing in recurrent IVF failures, poor ovarian reserve, and complex infertility cases — she combines advanced technology with a deeply personal approach to every patient's journey.
      </p>

      <div class="doctor-credentials" role="list" aria-label="Doctor credentials">
        <span class="credential" role="listitem"><i class="fa-solid fa-check" aria-hidden="true"></i> NABH Accredited</span>
        <span class="credential" role="listitem"><i class="fa-solid fa-check" aria-hidden="true"></i> IVF Specialist</span>
        <span class="credential" role="listitem"><i class="fa-solid fa-check" aria-hidden="true"></i> Laparoscopic Surgeon</span>
        <span class="credential" role="listitem"><i class="fa-solid fa-check" aria-hidden="true"></i> FOGSI Member</span>
        <span class="credential" role="listitem"><i class="fa-solid fa-check" aria-hidden="true"></i> ISAR Member</span>
      </div>

      <div class="doctor-stats">
        <div class="doctor-stat">
          <div class="number">2000+</div>
          <div class="label">IVF Cycles</div>
        </div>
        <div class="doctor-stat">
          <div class="number">75%</div>
          <div class="label">Success Rate</div>
        </div>
        <div class="doctor-stat">
          <div class="number">5.0★</div>
          <div class="label">Patient Rating</div>
        </div>
      </div>

      <a href="#contact" class="btn-rose doctor-cta">
        <i class="fa-solid fa-calendar-check" aria-hidden="true"></i>
        Book with Dr. Sharma
      </a>
    </div>
  </div>
</section>

<style>
  .doctor {
    padding: var(--section-pad);
    background: var(--midnight);
    position: relative;
    overflow: hidden;
  }

  .doctor::before {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(232, 76, 138, 0.12) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .doctor-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(50px, 8vw, 100px);
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* Image */
  .doctor-image { position: relative; }

  .doctor-img-wrapper {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: var(--shadow-glow);
  }

  .doctor-img-placeholder {
    width: 100%;
    aspect-ratio: 4/5;
    background: linear-gradient(180deg, var(--charcoal) 0%, var(--midnight) 100%);
    overflow: hidden;
  }

  .doctor-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 14%;
    display: block;
  }

  .doctor-exp-badge {
    position: absolute;
    bottom: -18px;
    right: -18px;
    background: var(--rose-gold);
    color: white;
    padding: 22px 28px;
    border-radius: 18px;
    text-align: center;
    box-shadow: var(--shadow-elegant);
  }
  .doctor-exp-badge .number {
    display: block;
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 300;
    line-height: 1;
  }
  .doctor-exp-badge .label {
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Info */
  .doctor-info { color: var(--champagne); }
  .doctor-info .section-tag { color: var(--rose-gold); }

  .doctor-info h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    font-weight: 300;
    color: var(--champagne);
    margin-bottom: 12px;
  }
  .doctor-info h2 em { font-style: italic; color: var(--rose-gold); }

  .doctor-title {
    font-size: 0.9rem;
    color: var(--gold);
    letter-spacing: 0.08em;
    margin-bottom: 28px;
    opacity: 0.9;
  }

  .doctor-info p {
    font-size: 0.97rem;
    color: rgba(255, 240, 232, 0.8);
    margin-bottom: 18px;
    font-weight: 300;
    line-height: 1.8;
  }

  .doctor-credentials {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .credential {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: rgba(232, 76, 138, 0.15);
    border: 1px solid rgba(232, 76, 138, 0.3);
    border-radius: 30px;
    font-size: 0.78rem;
    color: var(--champagne);
    letter-spacing: 0.05em;
  }
  .credential i { color: var(--rose-gold); font-size: 0.7rem; }

  .doctor-stats {
    display: flex;
    gap: 40px;
    margin-top: 40px;
    padding-top: 40px;
    border-top: 1px solid rgba(255, 240, 232, 0.1);
    flex-wrap: wrap;
  }

  .doctor-stat .number {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 2.5vw, 2.8rem);
    font-weight: 300;
    color: var(--rose-gold);
    line-height: 1;
  }
  .doctor-stat .label {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 240, 232, 0.55);
    margin-top: 6px;
  }

  .doctor-cta {
    margin-top: 36px;
  }

  /* Mobile */
  @media (max-width: 900px) {
    .doctor-inner {
      grid-template-columns: 1fr;
    }
    .doctor-image { max-width: 340px; margin: 0 auto; width: 100%; }
    .doctor-exp-badge { right: 0; bottom: -14px; }
    .doctor-stats { gap: 24px; }
  }
</style>
