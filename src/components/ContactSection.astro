---
import {
  contactDetails,
  doctorOptions,
  departmentOptions,
  timeSlotOptions,
} from '../data/siteContent';
---

<section class="contact" id="contact" aria-labelledby="contact-heading">
  <div class="contact-inner">
    <header class="section-header reveal">
      <span class="section-tag">Get in Touch</span>
      <h2 class="section-title" id="contact-heading">Begin Your <em>Journey</em></h2>
    </header>

    <div class="contact-grid">
      <aside class="contact-info reveal">
        <h3>We are Here for You</h3>
        <p>
          Speak with our fertility team for a clear diagnosis and a personalized treatment roadmap. Every conversation is private, respectful, and focused on outcomes.
        </p>
        <div class="contact-details">
          <div class="contact-item">
            <div class="contact-icon"><i class="fa-solid fa-phone"></i></div>
            <div>
              <h4>Phone</h4>
              <p><a href={`tel:${contactDetails.phone.replace(/\s+/g, '')}`}>{contactDetails.phone}</a></p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><i class="fa-solid fa-envelope"></i></div>
            <div>
              <h4>Email</h4>
              <p><a href={`mailto:${contactDetails.email}`}>{contactDetails.email}</a></p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><i class="fa-solid fa-location-dot"></i></div>
            <div>
              <h4>Location</h4>
              <p>{contactDetails.location}</p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><i class="fa-solid fa-clock"></i></div>
            <div>
              <h4>Hours</h4>
              <p>{contactDetails.hours}</p>
            </div>
          </div>
        </div>

      </aside>

      <div class="contact-form-wrapper reveal" id="contact-form">
        <h3 class="contact-form-title">Book Your Consultation</h3>
        <p class="contact-form-subtitle">Fill in your details and our team responds within 2 hours.</p>

        <form class="contact-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="fullName">Full Name <span>*</span></label>
              <input id="fullName" name="fullName" type="text" placeholder="Enter your name" required data-required="true" />
              <p class="field-error" id="fullName-error"></p>
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" placeholder="Enter email" />
              <p class="field-error" id="email-error"></p>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="phone">Phone <span>*</span></label>
              <input id="phone" name="phone" type="tel" placeholder="Phone number" required data-required="true" inputmode="tel" />
              <p class="field-error" id="phone-error"></p>
            </div>
            <div class="form-group">
              <label for="age">Age</label>
              <input id="age" name="age" type="number" placeholder="Age" min="18" max="60" />
              <p class="field-error" id="age-error"></p>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="doctor">Select Doctor</label>
              <select id="doctor" name="doctor">
                {doctorOptions.map((item) => (
                  <option value={item.value}>{item.label}</option>
                ))}
              </select>
              <p class="field-error" id="doctor-error"></p>
            </div>
            <div class="form-group">
              <label for="department">Department <span>*</span></label>
              <select id="department" name="department" required data-required="true">
                {departmentOptions.map((item) => (
                  <option value={item.value}>{item.label}</option>
                ))}
              </select>
              <p class="field-error" id="department-error"></p>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="preferredDate">Preferred Date</label>
              <input id="preferredDate" name="preferredDate" type="date" />
              <p class="field-error" id="preferredDate-error"></p>
            </div>
            <div class="form-group">
              <label for="preferredTime">Preferred Time</label>
              <select id="preferredTime" name="preferredTime">
                {timeSlotOptions.map((item) => (
                  <option value={item.value}>{item.label}</option>
                ))}
              </select>
              <p class="field-error" id="preferredTime-error"></p>
            </div>
          </div>

          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" placeholder="Any specific concerns or previous history..."></textarea>
            <p class="field-error" id="message-error"></p>
          </div>

          <button class="form-submit" type="submit">
            <i class="fa-solid fa-calendar-check" aria-hidden="true"></i>
            Request Appointment
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: clamp(58px, 8vw, 96px) clamp(18px, 4.4vw, 54px);
    background: linear-gradient(180deg, #fffdf9 0%, #fff5ef 100%);
  }

  .contact-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.2fr;
    gap: clamp(22px, 4vw, 48px);
  }

  .contact-info h3 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 14px;
    color: var(--midnight);
  }

  .contact-info > p {
    color: var(--charcoal);
    font-weight: 300;
    margin-bottom: 20px;
    max-width: 560px;
  }

  .contact-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    margin-bottom: 20px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .contact-icon {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    background: rgba(232, 76, 138, 0.12);
    color: var(--rose-gold);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-item h4 {
    color: var(--midnight);
    font-size: 0.82rem;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .contact-item p,
  .contact-item a {
    color: var(--charcoal);
    font-size: 0.95rem;
  }

  .contact-form-wrapper {
    background: #fffeff;
    border-radius: 22px;
    padding: clamp(20px, 2.5vw, 30px);
    box-shadow: 0 14px 28px rgba(31, 24, 38, 0.09);
  }

  .contact-form-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 500;
    margin-bottom: 6px;
    color: var(--midnight);
    line-height: 1.1;
  }

  .contact-form-subtitle {
    color: #64748b;
    margin-bottom: 16px;
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .form-group {
    margin-bottom: 10px;
  }

  .form-group label {
    display: block;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #5d6678;
    margin-bottom: 8px;
    font-weight: 600;
  }

  .form-group label span {
    color: var(--hot-pink);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid #d3d6dc;
    border-radius: 14px;
    font-family: var(--font-body);
    background: #f6f7f9;
    color: var(--midnight);
  }

  .form-group textarea {
    min-height: 120px;
    resize: vertical;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--hot-pink);
    box-shadow: 0 0 0 3px rgba(217, 22, 159, 0.15);
  }

  .field-error {
    min-height: 16px;
    font-size: 0.78rem;
    color: #c01771;
    margin-top: 6px;
  }

  .form-submit {
    width: 100%;
    border: 0;
    border-radius: 999px;
    padding: 14px;
    background: linear-gradient(92deg, var(--hot-orange) 0%, var(--hot-pink) 100%);
    color: white;
    letter-spacing: 0.04em;
    text-transform: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 1.18rem;
    font-weight: 600;
    line-height: 1;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    gap: 9px;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }

    .contact-form-wrapper {
      border-radius: 16px;
    }
  }
</style>

<script>
  const forms = document.querySelectorAll('.contact-form');

  const validators = {
    fullName: (value) => (value.trim().length < 2 ? 'Please enter your full name.' : ''),
    phone: (value) => (!/^\d{10}$/.test(value.replace(/\D/g, '')) ? 'Enter a valid 10-digit phone number.' : ''),
    email: (value) => {
      if (!value.trim()) return '';
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value.trim()) ? '' : 'Enter a valid email address.';
    },
    department: (value) => (!value ? 'Please select a department.' : ''),
  };

  const setError = (form, fieldName, message) => {
    const input = form.querySelector(`[name="${fieldName}"]`);
    const errorNode = form.querySelector(`#${fieldName}-error`);
    if (!input || !errorNode) return;

    input.setAttribute('aria-invalid', message ? 'true' : 'false');
    errorNode.textContent = message;
  };

  const validateField = (form, fieldName) => {
    const input = form.querySelector(`[name="${fieldName}"]`);
    if (!input) return '';
    const fn = validators[fieldName];
    const message = fn ? fn(input.value) : '';
    setError(form, fieldName, message);
    return message;
  };

  forms.forEach((form) => {
    const fields = ['fullName', 'phone', 'email', 'department'];

    fields.forEach((field) => {
      const input = form.querySelector(`[name="${field}"]`);
      input?.addEventListener('blur', () => validateField(form, field));
      input?.addEventListener('input', () => validateField(form, field));
    });

    form.addEventListener('submit', (event) => {
      let hasError = false;
      fields.forEach((field) => {
        if (validateField(form, field)) hasError = true;
      });

      if (hasError) {
        event.preventDefault();
        const firstInvalid = form.querySelector('[aria-invalid="true"]');
        firstInvalid?.focus();
      }
    });
  });
</script>
