---
import { contactDetails, services } from '../data/siteContent';
---

<section class="contact" id="contact" aria-labelledby="contact-heading">
  <div class="contact-inner">
    <header class="section-header reveal">
      <span class="section-tag">Get in Touch</span>
      <h2 class="section-title" id="contact-heading">Begin Your <em>Journey</em></h2>
    </header>

    <div class="contact-grid">
      <aside class="contact-info reveal">
        <h3>We are Here for You</h3>
        <p>
          Speak with our fertility team for a clear diagnosis and a personalized treatment roadmap. Every conversation is private, respectful, and focused on outcomes.
        </p>
        <div class="contact-details">
          <div class="contact-item">
            <div class="contact-icon"><i class="fa-solid fa-phone"></i></div>
            <div>
              <h4>Phone</h4>
              <p><a href={`tel:${contactDetails.phone.replace(/\s+/g, '')}`}>{contactDetails.phone}</a></p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><i class="fa-solid fa-envelope"></i></div>
            <div>
              <h4>Email</h4>
              <p><a href={`mailto:${contactDetails.email}`}>{contactDetails.email}</a></p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><i class="fa-solid fa-location-dot"></i></div>
            <div>
              <h4>Location</h4>
              <p>{contactDetails.location}</p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><i class="fa-solid fa-clock"></i></div>
            <div>
              <h4>Hours</h4>
              <p>{contactDetails.hours}</p>
            </div>
          </div>
        </div>
      </aside>

      <div class="contact-form-wrapper reveal" id="contact-form">
        <h3 class="contact-form-title">Book a Consultation</h3>
        <form class="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Full Name</label>
              <input id="name" name="name" type="text" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input id="phone" name="phone" type="tel" placeholder="Your phone" required />
            </div>
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input id="email" name="email" type="email" placeholder="Your email" />
          </div>
          <div class="form-group">
            <label for="service">Select Service</label>
            <select id="service" name="service">
              <option value="">Choose a service</option>
              {services.map((service) => (
                <option value={service.id}>{service.title}</option>
              ))}
            </select>
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" placeholder="Tell us about your concerns..."></textarea>
          </div>
          <button class="form-submit" type="submit">Request Appointment</button>
        </form>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: var(--section-pad);
    background: linear-gradient(180deg, var(--cream) 0%, var(--champagne-light) 100%);
  }

  .contact-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(30px, 5vw, 70px);
  }

  .contact-info h3 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 300;
    line-height: 1.2;
    margin-bottom: 14px;
    color: var(--midnight);
  }

  .contact-info > p {
    color: var(--charcoal);
    font-weight: 300;
    margin-bottom: 30px;
    max-width: 560px;
  }

  .contact-details {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .contact-icon {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    background: rgba(232, 76, 138, 0.12);
    color: var(--rose-gold);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-item h4 {
    color: var(--midnight);
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .contact-item p,
  .contact-item a {
    color: var(--charcoal);
    font-size: 0.95rem;
  }

  .contact-form-wrapper {
    background: white;
    border-radius: 24px;
    padding: clamp(24px, 3vw, 36px);
    box-shadow: var(--shadow-soft);
  }

  .contact-form-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 300;
    margin-bottom: 20px;
    color: var(--midnight);
  }

  .form-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .form-group {
    margin-bottom: 14px;
  }

  .form-group label {
    display: block;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--charcoal);
    margin-bottom: 8px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 14px 16px;
    border: 1px solid var(--champagne);
    border-radius: 12px;
    font-family: var(--font-body);
    background: var(--cream);
    color: var(--midnight);
  }

  .form-group textarea {
    min-height: 120px;
    resize: vertical;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--rose-gold);
    box-shadow: 0 0 0 3px rgba(232, 76, 138, 0.12);
  }

  .form-submit {
    width: 100%;
    border: 0;
    border-radius: 12px;
    padding: 16px;
    background: var(--midnight);
    color: white;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .form-submit:hover {
    background: var(--rose-gold);
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
