---
import { reviews } from '../data/siteContent';
---

<section class="reviews" id="reviews" aria-labelledby="reviews-heading">
  <div class="reviews-inner">
    <header class="reviews-header reveal">
      <span class="section-tag">Real People, Real Results</span>
      <h2 class="section-title" id="reviews-heading">Real Stories, <em>Real Families</em></h2>
      <p class="section-subtitle">
        Thousands of families have completed their journey with us.
      </p>
    </header>

    <div class="reviews-track" role="list">
      {reviews.map((item, idx) => (
        <article class="review-card reveal" role="listitem" style={`animation-delay: ${idx * 0.08}s`}>
          <div class="review-hearts" aria-label="5 heart rating">
            <i class="fa-solid fa-heart"></i>
            <i class="fa-solid fa-heart"></i>
            <i class="fa-solid fa-heart"></i>
            <i class="fa-solid fa-heart"></i>
            <i class="fa-solid fa-heart"></i>
          </div>
          <p class="review-quote">"{item.quote}"</p>
          <div class="review-meta">
            <div class="review-avatar">{item.name.slice(0, 1)}</div>
            <div>
              <p class="review-name">{item.name}</p>
              <p class="review-city">{item.city}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews {
    padding: clamp(56px, 8vw, 100px) clamp(18px, 4.4vw, 54px);
    background: linear-gradient(180deg, var(--cream) 0%, #fff7f1 100%);
    position: relative;
    overflow: hidden;
  }

  .reviews::before {
    content: '';
    position: absolute;
    width: 420px;
    height: 420px;
    left: -170px;
    top: 40px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232, 76, 138, 0.13) 0%, rgba(232, 76, 138, 0) 72%);
    pointer-events: none;
  }

  .reviews-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .reviews-header {
    margin-bottom: 30px;
  }

  .reviews-track {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 16px;
  }

  .review-card {
    background: #fff;
    border-radius: 18px;
    padding: 18px;
    border: 1px solid rgba(232, 76, 138, 0.16);
    box-shadow: 0 10px 22px rgba(33, 24, 38, 0.08);
  }

  .review-hearts {
    color: #d92f87;
    display: flex;
    gap: 5px;
    margin-bottom: 10px;
    font-size: 0.82rem;
  }

  .review-quote {
    color: var(--charcoal);
    font-size: 0.88rem;
    line-height: 1.65;
    min-height: 140px;
  }

  .review-meta {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 14px;
  }

  .review-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--hot-orange) 0%, var(--hot-pink) 100%);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.86rem;
  }

  .review-name {
    color: var(--midnight);
    font-weight: 600;
    line-height: 1.2;
    font-size: 0.9rem;
  }

  .review-city {
    color: #6b7280;
    font-size: 0.78rem;
    line-height: 1.2;
  }

  @media (max-width: 1200px) {
    .reviews-track {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 900px) {
    .reviews-track {
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(76%, 1fr);
      overflow-x: auto;
      padding-bottom: 8px;
      scroll-snap-type: x mandatory;
    }

    .review-card {
      scroll-snap-align: start;
    }

    .review-quote {
      min-height: auto;
    }
  }
</style>
