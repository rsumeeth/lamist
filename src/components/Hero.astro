---
import { heroPills, heroQuote, heroStats } from '../data/siteContent';
---

<section class="hero" id="home" aria-label="Hero section">
  <div class="hero-bg-pattern" aria-hidden="true"></div>

  <div class="hero-content">
    <div class="hero-intro">
      <div class="hero-badge" id="hero-badge">
        <i class="fa-solid fa-heart"></i>
        <span class="trust-text">Delhi's Most Trusted IVF Centre</span>
        <span class="sparkle sparkle-1" aria-hidden="true">*</span>
        <span class="sparkle sparkle-2" aria-hidden="true">*</span>
      </div>

      <h1>
        Helping You Start Your<br />
        <em>Parenthood Journey</em>
      </h1>
    </div>

    <div class="hero-visual">
      <div class="hero-image-wrapper">
        <canvas id="hero-fx-canvas" class="hero-fx-canvas"></canvas>

        <div class="hero-img-placeholder">
          <img
            src="/images/hero/hero-lamist-people-2.png"
            alt="LAMNIST fertility specialist team"
            class="hero-photo"
            loading="eager"
          />
        </div>

        <button class="hero-ripple-btn" type="button" aria-label="Patient-first care highlight">
          <i class="fa-solid fa-heart"></i>
        </button>

        <!-- <div class="hero-cert hero-cert-excellence">
          <span class="hero-cert-icon"><i class="fa-solid fa-award"></i></span>
          <div class="hero-cert-text">
            <p class="hero-cert-value">20+</p>
            <p class="hero-cert-label">Years of Excellence</p>
          </div>
        </div> -->

        <!-- <div class="hero-cert hero-cert-nabh">
          <span class="hero-cert-icon"><i class="fa-solid fa-shield-heart"></i></span>
          <div class="hero-cert-text">
            <p class="hero-cert-value">NABH</p>
            <p class="hero-cert-label">Accredited Clinic</p>
          </div>
        </div> -->

        {heroPills.map((pill, index) => (
          <div class={`hero-pill hero-pill-${index + 1}`}>
            <div class="hero-pill-icon">{pill.icon}</div>
            <div>
              <p class="hero-pill-label">{pill.label}</p>
              <p class="hero-pill-value">{pill.value}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="hero-quote-below">"{heroQuote}"</p>
    </div>

    <div class="hero-support">
      <p class="hero-description">
        We care for the most delicate chapter of your life with clinical precision and genuine tenderness. From your first consultation to your first heartbeat scan, we stay beside you with clarity, warmth, and hope.
      </p>

      <div class="hero-buttons">
        <a href="/contact#contact-form" class="btn-rose hero-btn-primary">
          <i class="fa-solid fa-calendar-check"></i>
          Schedule Appointment
        </a>
      </div>

      <div class="hero-stats">
        {heroStats.map((item) => (
          <div class="stat">
            <div class="stat-number">{item.value}</div>
            <div class="stat-label">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    align-items: flex-start;
    position: relative;
    background: linear-gradient(135deg, var(--champagne-light) 0%, var(--cream) 55%, var(--blush) 100%);
    overflow: hidden;
    padding-top: 74px;
  }

  .hero::after {
    content: '';
    position: absolute;
    width: 430px;
    height: 430px;
    right: -140px;
    top: 80px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(233, 30, 99, 0.15) 0%, rgba(233, 30, 99, 0) 72%);
    pointer-events: none;
  }

  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0L60 30L30 60L0 30Z' fill='none' stroke='%23E84C8A' stroke-width='0.4' opacity='0.08'/%3E%3C/svg%3E");
    pointer-events: none;
  }

  /* .hero-bg-pattern::after { */
    /* content: ''; */
    /* position: absolute; */
    /* inset: 0; */
    /* background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0L60 30L30 60L0 30Z' fill='none' stroke='%23E84C8A' stroke-width='0.35' opacity='0.08'/%3E%3Cpath d='M30 4c-1.8-2.4-5.2-1.6-5.2 1.3 0 2.7 5.2 5.7 5.2 5.7s5.2-3 5.2-5.7c0-2.9-3.4-3.7-5.2-1.3z' fill='%23E84C8A' opacity='0.16'/%3E%3Cpath d='M56 30c-2.4-1.8-1.6-5.2 1.3-5.2 2.7 0 5.7 5.2 5.7 5.2s-3 5.2-5.7 5.2c-2.9 0-3.7-3.4-1.3-5.2z' fill='%23E84C8A' opacity='0.16'/%3E%3Cpath d='M30 56c1.8 2.4 5.2 1.6 5.2-1.3 0-2.7-5.2-5.7-5.2-5.7s-5.2 3-5.2 5.7c0 2.9 3.4 3.7 5.2 1.3z' fill='%23E84C8A' opacity='0.16'/%3E%3Cpath d='M4 30c2.4 1.8 1.6 5.2-1.3 5.2-2.7 0-5.7-5.2-5.7-5.2s3-5.2 5.7-5.2c2.9 0 3.7 3.4 1.3 5.2z' fill='%23E84C8A' opacity='0.16'/%3E%3C/svg%3E"); */
    /* background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0L60 30L30 60L0 30Z' fill='none' stroke='%23E84C8A' stroke-width='0.35' opacity='0.08'/%3E%3Cpath d='M30 4.5c-1.8-2.4-5.2-1.6-5.2 1.3 0 2.7 5.2 5.7 5.2 5.7s5.2-3 5.2-5.7c0-2.9-3.4-3.7-5.2-1.3z' fill='%23E84C8A' opacity='0.2'/%3E%3C/svg%3E"); */
    /* pointer-events: none; */
  /* } */

  .hero-content {
    max-width: var(--max-width);
    margin: 0 auto;
    width: 100%;
    padding: clamp(28px, 4.8vw, 60px) clamp(18px, 4.2vw, 52px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(18px, 3.5vw, 44px);
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .hero-intro {
    grid-column: 1;
    grid-row: 1;
  }

  .hero-support {
    grid-column: 1;
    grid-row: 2;
  }

  .hero-visual {
    grid-column: 2;
    grid-row: 1 / span 2;
    position: relative;
  }

  .hero-badge {
    display: inline-flex;
    position: relative;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: linear-gradient(90deg, rgba(247, 185, 44, 0.16) 0%, rgba(232, 76, 138, 0.14) 100%);
    border: 1px solid rgba(232, 76, 138, 0.28);
    border-radius: 999px;
    font-size: 0.63rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rose-gold);
    margin-bottom: 18px;
    overflow: hidden;
  }

  .hero-badge i { font-size: 0.65rem; color: #d92f87; }

  .trust-text {
    display: inline-block;
    opacity: 0;
    transform: scale(1.05);
    filter: blur(7px);
  }

  .hero-badge.is-assembled .trust-text {
    animation: reverseSnapAssemble 1.1s ease forwards;
  }

  .sparkle {
    position: absolute;
    color: #f4a261;
    font-size: 0.6rem;
    opacity: 0;
    transform: translateY(6px) scale(0.8);
  }

  .sparkle-1 { right: 10px; top: 5px; }
  .sparkle-2 { right: 28px; bottom: 4px; }

  .hero-badge.is-assembled .sparkle {
    animation: sparkleRise 1.05s ease 0.48s forwards;
  }

  .hero-badge::before,
  .hero-badge::after {
    content: '';
    position: absolute;
    width: 45%;
    height: 150%;
    top: -25%;
    background-image: radial-gradient(circle at center, rgba(255, 255, 255, 0.75) 0 1px, transparent 1.2px);
    background-size: 10px 10px;
    opacity: 0;
    pointer-events: none;
  }

  .hero-badge::before { left: -45%; }
  .hero-badge::after { right: -45%; }
  .hero-badge.is-assembled::before { animation: dustFromLeft 1.05s ease forwards; }
  .hero-badge.is-assembled::after { animation: dustFromRight 1.05s ease forwards; }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 4.8vw, 4.4rem);
    font-weight: 400;
    line-height: 1.04;
    color: var(--midnight);
    max-width: 14ch;
  }

  h1 em {
    font-style: italic;
    color: var(--rose-gold);
    font-weight: 500;
  }

  .hero-description {
    font-size: clamp(0.92rem, 1.3vw, 1.04rem);
    color: #6d6d79;
    margin-bottom: 22px;
    max-width: 54ch;
    font-weight: 300;
    line-height: 1.68;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 22px;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    padding-top: 18px;
    border-top: 1px solid rgba(26, 26, 46, 0.08);
  }

  .stat-number {
    font-family: var(--font-display);
    font-size: clamp(1.65rem, 2.4vw, 2.4rem);
    font-weight: 500;
    color: var(--rose-gold);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--charcoal);
    margin-top: 5px;
  }

  .hero-image-wrapper {
    position: relative;
    border-radius: 230px 230px 24px 24px;
    overflow: visible;
    min-height: 540px;
  }

  .hero-fx-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    pointer-events: none;
    z-index: 1;
    opacity: 0.56;
  }

  .hero-img-placeholder {
    position: relative;
    z-index: 2;
    width: 100%;
    aspect-ratio: 3/4;
    background: linear-gradient(180deg, var(--champagne) 0%, var(--blush) 100%);
    border-radius: inherit;
    box-shadow: var(--shadow-elegant);
    overflow: hidden;
  }

  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 24%;
    display: block;
  }

  .hero-ripple-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 0;
    background: rgb(241 241 241 / 4%);
    color: #d92f87;
    box-shadow: 0 10px 28px rgba(34, 23, 37, 0.2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .hero-ripple-btn i { font-size: 1.05rem; }

  .hero-ripple-btn::before,
  .hero-ripple-btn::after {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1.5px solid rgba(217, 47, 135, 0.35);
    animation: rippleRing 2s infinite;
  }

  .hero-ripple-btn::after {
    inset: -18px;
    border-width: 1px;
    border-color: rgba(217, 47, 135, 0.2);
    animation-delay: 0.5s;
  }

  .hero-quote-below {
    width: min(96%, 420px);
    text-align: center;
    margin: 14px auto 0;
    z-index: 2;
    font-family: var(--font-display);
    font-size: 1.02rem;
    font-style: italic;
    color: rgba(26, 26, 46, 0.82);
    line-height: 1.35;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(232, 76, 138, 0.16);
    border-radius: 999px;
    padding: 10px 16px;
    box-shadow: 0 8px 24px rgba(26, 26, 46, 0.08);
  }

  .hero-cert {
    position: absolute;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: rgba(255, 255, 255, 0.96);
    border: 1px solid rgba(232, 76, 138, 0.2);
    border-radius: 999px;
    padding: 8px 12px;
    box-shadow: 0 8px 20px rgba(33, 23, 37, 0.14);
    backdrop-filter: blur(6px);
  }

  .hero-cert-icon {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(247, 185, 44, 0.22), rgba(232, 76, 138, 0.22));
    color: #c2337b;
    flex-shrink: 0;
    font-size: 0.82rem;
  }

  .hero-cert-value {
    font-family: var(--font-display);
    font-size: 0.95rem;
    line-height: 1;
    color: var(--midnight);
    font-weight: 600;
  }

  .hero-cert-label {
    font-size: 0.56rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #71667b;
    line-height: 1.15;
    margin-top: 3px;
    font-weight: 500;
  }

  .hero-cert-excellence {
    left: -52px;
    top: 22%;
  }

  .hero-cert-nabh {
    left: -48px;
    bottom: 14%;
  }

  .hero-pill {
    position: absolute;
    z-index: 4;
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.95);
    border-radius: 999px;
    padding: 8px 14px;
    box-shadow: 0 8px 24px rgba(33, 23, 37, 0.13);
    animation: floatingCard 4.4s ease-in-out infinite;
  }

  .hero-pill-icon {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--champagne), var(--blush));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 0.95rem;
  }

  .hero-pill-label {
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #7c7284;
    font-weight: 500;
    line-height: 1.1;
  }

  .hero-pill-value {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--midnight);
    line-height: 1.2;
    font-weight: 500;
  }

  .hero-pill-1 {
    top: 15%;
    right: -52px;
  }

  .hero-pill-2 {
    left: -62px;
    bottom: 26%;
    animation-delay: 1.2s;
  }

  .hero-pill-3 {
    right: -30px;
    bottom: 8%;
    animation-delay: 0.7s;
  }

  @media (max-width: 1100px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .hero-intro,
    .hero-support,
    .hero-visual {
      grid-column: 1;
    }

    .hero-intro {
      grid-row: 1;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .hero-visual { grid-row: 2; max-width: 340px; margin: 0 auto; width: 100%; }
    .hero-support { grid-row: 3; }

    h1 { max-width: none; }

    .hero-image-wrapper {
      min-height: 0;
    }

    .hero-pill-1 {
      right: -28px;
      top: 10%;
    }

    .hero-pill-2 {
      left: -28px;
      bottom: 24%;
    }

    .hero-pill-3 {
      right: -16px;
      bottom: 4%;
    }

    .hero-cert-excellence {
      left: -26px;
      top: 18%;
    }

    .hero-cert-nabh {
      left: -26px;
      bottom: 18%;
    }
  }

  @media (max-width: 900px) {
    .hero {
      padding-top: 70px;
      min-height: auto;
    }

    .hero-content {
      padding: 28px clamp(16px, 4vw, 26px) 54px;
      gap: 14px;
    }

    .hero-visual {
      max-width: 304px;
    }

    .hero-ripple-btn {
      width: 56px;
      height: 56px;
    }

    .hero-quote-below {
      font-size: 0.92rem;
      margin-top: 10px;
      padding: 9px 12px;
    }

    .hero-buttons {
      margin-bottom: 16px;
    }

    .hero-btn-primary {
      width: 100%;
      justify-content: center;
    }

    .hero-stats {
      gap: 10px;
    }

    .hero-pill {
      padding: 6px 10px;
      gap: 8px;
    }

    .hero-pill-icon {
      width: 26px;
      height: 26px;
      font-size: 0.86rem;
    }

    .hero-pill-label {
      font-size: 0.52rem;
      letter-spacing: 0.08em;
    }

    .hero-pill-value {
      font-size: 0.82rem;
    }

    .hero-pill-1 { right: -12px; top: 6%; }
    .hero-pill-2 { left: -14px; bottom: 22%; }
    .hero-pill-3 { right: 106px; bottom: 3%; }

    .hero-cert {
      padding: 6px 10px;
      gap: 7px;
    }

    .hero-cert-icon {
      width: 24px;
      height: 24px;
      font-size: 0.7rem;
    }

    .hero-cert-value {
      font-size: 0.8rem;
    }

    .hero-cert-label {
      font-size: 0.48rem;
      letter-spacing: 0.06em;
      margin-top: 2px;
    }

    .hero-cert-excellence { left: -10px; top: 14%; }
    .hero-cert-nabh { left: -10px; bottom: 16%; }
  }

  @media (max-width: 520px) {
    .hero-visual { max-width: 264px; }
    .hero-pill-2 { display: none; }
  }

  @keyframes reverseSnapAssemble {
    0% { opacity: 0; filter: blur(7px); transform: scale(1.07); }
    60% { opacity: 0.85; filter: blur(1px); }
    100% { opacity: 1; filter: blur(0); transform: scale(1); }
  }

  @keyframes dustFromLeft {
    0% { opacity: 0.5; transform: translateX(70%); }
    90% { opacity: 0.35; }
    100% { opacity: 0; transform: translateX(145%); }
  }

  @keyframes dustFromRight {
    0% { opacity: 0.5; transform: translateX(-70%); }
    90% { opacity: 0.35; }
    100% { opacity: 0; transform: translateX(-145%); }
  }

  @keyframes sparkleRise {
    0% { opacity: 0; transform: translateY(8px) scale(0.8); }
    50% { opacity: 0.9; }
    100% { opacity: 0.2; transform: translateY(-6px) scale(1); }
  }

  @keyframes floatingCard {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes rippleRing {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(1.32); opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-text {
      opacity: 1;
      filter: none;
      transform: none;
    }

    .sparkle,
    .hero-badge::before,
    .hero-badge::after,
    .hero-pill,
    .hero-ripple-btn::before,
    .hero-ripple-btn::after {
      animation: none;
      display: none;
    }
  }
</style>

<script>
  const heroBadge = document.getElementById('hero-badge');

  if (heroBadge) {
    window.setTimeout(() => {
      heroBadge.classList.add('is-assembled');
    }, 320);
  }


</script>
