---
import MainLayout from '../layouts/MainLayout.astro';
import HeroNav from '../components/HeroNav.astro';
---

<MainLayout
  title="About Us | Femme Nest Hospital"
  description="Learn about Femme Nest Hospital's vision, mission, values, and world-class facility for women's and child care in East Delhi."
  canonical="https://www.femmenest.com/about"
  ogImage="/images/fn/about-hero-family.jpg"
  showFooter={false}
  showConversionAssist={false}
>
  <div class="about-page">
  <HeroNav theme="about" />
  <main>
    <section class="about-hero">
      <img src="/images/fn/about-hero-family.jpg" alt="Femme Nest Hospital women and child care team" />
      <div class="about-hero-content">
        <span class="section-tag section-tag-light">About Us</span>
        <h1>Boutique Hospital for <br />Women &amp; Child Care</h1>
        <p>
          At Femme Nest Hospital, we believe every woman deserves world-class healthcare in an environment
          that feels personal, warm, and nurturing.
        </p>
      </div>
    </section>

    <section class="about-sections" aria-label="About Femme Nest">
      <article class="about-card">
        <div class="about-card-icon">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>
        </div>
        <h2>Our Vision</h2>
        <p>
          To be India's most trusted and compassionate women's and child care hospital where clinical
          excellence meets the warmth of a boutique experience.
        </p>
      </article>

      <article class="about-card">
        <div class="about-card-icon">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
        </div>
        <h2>Our Mission</h2>
        <p>
          To deliver evidence-based healthcare for women and children through dedicated specialists,
          modern technology, and a nurturing experience where every patient feels heard and respected.
        </p>
      </article>

      <article class="about-card">
        <div class="about-card-icon">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"></path></svg>
        </div>
        <h2>Our Values</h2>
        <ul>
          <li><strong>Compassion First</strong> Every patient is treated with warmth, patience, and dignity.</li>
          <li><strong>Clinical Excellence</strong> Modern equipment and specialist-led, evidence-based care.</li>
          <li><strong>24/7 Availability</strong> Critical teams are available around the clock.</li>
          <li><strong>Complete Care</strong> From preconception to postnatal support under one roof.</li>
        </ul>
      </article>

      <article class="about-card">
        <div class="about-card-icon">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
        </div>
        <h2>Our Story</h2>
        <p>
          Femme Nest Hospital was founded to redefine women's healthcare in India with privacy, warmth,
          and integrated care, including private birthing suites and advanced newborn support.
        </p>
      </article>
    </section>

    <section class="about-gallery" aria-label="Facility gallery">
      <h2>Our World-Class Facility</h2>
      <div class="about-gallery-grid">
        <img src="/images/fn/interior-1.jpeg" alt="Femme Nest Hospital interior" loading="lazy" />
        <img src="/images/fn/interior-3.jpeg" alt="Femme Nest Hospital suite" loading="lazy" />
        <img src="/images/fn/interior-5.jpeg" alt="Femme Nest Hospital corridor" loading="lazy" />
        <img src="/images/fn/interior-7.jpeg" alt="Femme Nest Hospital room" loading="lazy" />
        <img src="/images/fn/interior-10.jpeg" alt="Femme Nest Hospital facility" loading="lazy" />
        <img src="/images/fn/interior-12.jpeg" alt="Femme Nest Hospital reception" loading="lazy" />
        <img src="/images/fn/interior-14.jpeg" alt="Femme Nest Hospital ward" loading="lazy" />
        <img src="/images/fn/interior-2.jpeg" alt="Femme Nest Hospital lounge" loading="lazy" />
      </div>
    </section>

    <section class="about-cta">
      <h2>Boutique Hospital for Women &amp; Child Care</h2>
      <p>Book your consultation with our senior specialists today.</p>
      <a href="/contact#contact-form" class="btn-rose">Book Consultation</a>
    </section>
  </main>
  <footer class="ex-foot">&copy; Femme Nest Hospital &middot; Boutique Hospital for Women &amp; Child Care</footer>
  </div>
</MainLayout>

<style is:global>
  .about-page {
    --about-font-display: 'Playfair Display', serif;
    --about-font-body: 'Inter', sans-serif;
    background: #fdf8f4;
    font-family: var(--about-font-body);
  }

  .about-page .about-hero,
  .about-page .about-sections,
  .about-page .about-gallery,
  .about-page .about-cta,
  .about-page .ex-foot {
    font-family: var(--about-font-body);
  }

  .about-page h1,
  .about-page h2,
  .about-page h3 {
    font-family: var(--about-font-display);
  }

  .about-page .ex-foot {
    text-align: center;
    padding: 2rem;
    color: #6b5a54;
    font-size: 0.9rem;
    border-top: 1px solid rgba(45, 31, 26, 0.08);
  }

  .about-hero {
    position: relative;
    height: clamp(340px, 52vw, 440px);
    margin-top: 100px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-hero img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(26, 26, 46, 0.66), rgba(232, 76, 138, 0.46));
  }

  .about-hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
    max-width: 860px;
    padding: 0 clamp(20px, 4vw, 46px);
  }

  .section-tag-light {
    color: #fff;
    display: inline-block;
    margin-bottom: 12px;
    background: rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    padding: 0.36rem 1rem;
    letter-spacing: 0.12em;
  }

  .about-hero h1 {
    font-size: clamp(2rem, 5vw, 3.6rem);
    font-weight: 700;
    line-height: 1.1;
  }

  .about-hero p {
    margin: 1rem auto 0;
    max-width: 720px;
    color: rgba(255, 255, 255, 0.94);
    font-size: 1.04rem;
  }

  .about-sections {
    max-width: 1200px;
    margin: clamp(42px, 6vw, 72px) auto 0;
    padding: 0 clamp(18px, 4vw, 42px);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(16px, 2.2vw, 28px);
  }

  .about-card {
    background: #fff;
    border-radius: 24px;
    padding: clamp(24px, 3vw, 36px);
    box-shadow: 0 15px 50px rgba(45, 31, 26, 0.06);
  }

  .about-card-icon {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(232, 76, 138, 0.12), rgba(242, 140, 40, 0.12));
    color: var(--rose-gold);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .about-card h2 {
    font-size: clamp(1.55rem, 2.5vw, 2rem);
    line-height: 1.2;
    margin-bottom: 0.75rem;
    color: var(--midnight);
  }

  .about-card p,
  .about-card li {
    color: var(--charcoal);
    font-size: 1rem;
    line-height: 1.75;
  }

  .about-card ul {
    list-style: none;
    margin-top: 0.5rem;
  }

  .about-card li {
    position: relative;
    padding-left: 1.25rem;
  }

  .about-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.72rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--rose-gold), var(--hot-orange));
  }

  .about-card li + li {
    margin-top: 0.3rem;
  }

  .about-card strong {
    color: var(--midnight);
  }

  .about-gallery {
    max-width: 1200px;
    margin: clamp(46px, 7vw, 86px) auto 0;
    padding: 0 clamp(18px, 4vw, 42px);
  }

  .about-gallery h2,
  .about-cta h2 {
    font-size: clamp(1.9rem, 4vw, 2.8rem);
    color: var(--midnight);
  }

  .about-gallery h2 {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .about-gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .about-gallery-grid img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 18px;
    box-shadow: 0 10px 24px rgba(26, 26, 46, 0.08);
  }

  .about-cta {
    max-width: 1100px;
    margin: clamp(48px, 7vw, 88px) auto;
    padding: clamp(28px, 5vw, 56px) clamp(20px, 4vw, 50px);
    border-radius: 28px;
    text-align: center;
    background: linear-gradient(120deg, var(--champagne) 0%, #fff 45%, var(--blush) 100%);
  }

  .about-cta p {
    margin: 0.8rem auto 1.3rem;
    max-width: 620px;
    color: var(--charcoal);
  }

  @media (max-width: 960px) {
    .about-sections {
      grid-template-columns: 1fr;
    }

    .about-gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 600px) {
    .about-hero {
      margin-top: 92px;
    }
  }
</style>
