---
import MainLayout from '../layouts/MainLayout.astro';
import HeroNav from '../components/HeroNav.astro';
import { teamConsultants, visitingConsultants } from '../data/doctorsContent';
---

<MainLayout
  title="Our Doctors | Femme Nest Hospital"
  description="Meet the trusted specialists at Femme Nest Hospital including obstetricians, gynaecologists, and visiting consultants in East Delhi."
  canonical="https://www.femmenest.com/doctors"
  ogImage="/images/fn/ai-medical-team.jpg"
  showFooter={false}
  showConversionAssist={false}
>
  <div class="doctors-page">
    <HeroNav theme="about" />

    <main>
      <section class="dr-hero">
        <img class="dr-hero-bg" src="/images/fn/ai-medical-team.jpg" alt="Femme Nest Hospital doctors team" />
        <div class="dr-hero-content">
          <span class="dr-label">Our Doctors</span>
          <h1>Meet Our Specialists</h1>
          <p>
            A team of highly qualified obstetricians, gynaecologists, fertility experts,
            neonatologists, and paediatricians dedicated to your care.
          </p>
        </div>
      </section>

      <div class="dr-search-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="M21 21l-4.35-4.35"></path>
        </svg>
        <input type="text" id="drSearch" placeholder="Search by doctor name, speciality, or degree..." />
      </div>

      <section class="dr-section" id="teamSection">
        <h2 class="dr-section-title">Team Consultants</h2>
        <p class="dr-section-sub">Our full-time specialists who lead patient care at Femme Nest Hospital.</p>
        <div class="dr-grid" id="teamGrid">
          {teamConsultants.map((doctor) => (
            <article
              class="dr-card"
              data-doctor-card
              data-name={doctor.name.toLowerCase()}
              data-specialty={doctor.specialty.toLowerCase()}
              data-degree={doctor.degree.toLowerCase()}
            >
              <img class="dr-card-img" src={doctor.image} alt={doctor.name} loading="lazy" />
              <div class="dr-card-body">
                <h3 class="dr-card-name">{doctor.name}</h3>
                <p class="dr-card-spec">{doctor.specialty}</p>
                <p class="dr-card-degree">{doctor.degree}</p>
                {doctor.schedule && <p class="dr-card-schedule">{doctor.schedule}</p>}
                <a class="dr-card-link" href={`/doctors/${doctor.slug}`}>
                  Learn More
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14"></path>
                    <path d="M12 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="dr-section" id="visitingSection">
        <h2 class="dr-section-title">Visiting Consultants</h2>
        <p class="dr-section-sub">Senior specialists who visit on scheduled days to provide expert consultation.</p>
        <div class="dr-grid" id="visitingGrid">
          {visitingConsultants.map((doctor) => (
            <article
              class="dr-card"
              data-doctor-card
              data-name={doctor.name.toLowerCase()}
              data-specialty={doctor.specialty.toLowerCase()}
              data-degree={doctor.degree.toLowerCase()}
            >
              <img class="dr-card-img" src={doctor.image} alt={doctor.name} loading="lazy" />
              <div class="dr-card-body">
                <h3 class="dr-card-name">{doctor.name}</h3>
                <p class="dr-card-spec">{doctor.specialty}</p>
                <p class="dr-card-degree">{doctor.degree}</p>
                {doctor.schedule && <p class="dr-card-schedule">{doctor.schedule}</p>}
                <a class="dr-card-link" href={`/doctors/${doctor.slug}`}>
                  Learn More
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M5 12h14"></path>
                    <path d="M12 5l7 7-7 7"></path>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <p class="dr-empty-state" id="drEmptyState" hidden>No doctors found for your search. Try a different keyword.</p>
    </main>

    <footer class="ex-foot">&copy; Femme Nest Hospital &middot; Boutique Hospital for Women &amp; Child Care</footer>
  </div>
</MainLayout>

<script>
  const searchInput = document.getElementById('drSearch');
  const cards = Array.from(document.querySelectorAll('[data-doctor-card]'));
  const emptyState = document.getElementById('drEmptyState');

  const filterDoctors = () => {
    const q = (searchInput?.value ?? '').trim().toLowerCase();
    let visibleCount = 0;

    cards.forEach((card) => {
      const name = card.getAttribute('data-name') ?? '';
      const specialty = card.getAttribute('data-specialty') ?? '';
      const degree = card.getAttribute('data-degree') ?? '';
      const matches = name.includes(q) || specialty.includes(q) || degree.includes(q);
      card.style.display = matches ? '' : 'none';
      if (matches) visibleCount += 1;
    });

    if (emptyState) emptyState.hidden = visibleCount !== 0;
  };

  if (searchInput) {
    searchInput.addEventListener('input', filterDoctors);
  }
</script>

<style is:global>
  .doctors-page {
    --doctors-font-display: 'Playfair Display', serif;
    --doctors-font-body: 'Inter', sans-serif;
    background: #fdf8f4;
    font-family: var(--doctors-font-body);
  }

  .doctors-page main {
    padding-bottom: 2rem;
  }

  .doctors-page .ex-foot {
    text-align: center;
    padding: 2rem;
    color: #6b5a54;
    font-size: 0.9rem;
    border-top: 1px solid rgba(45, 31, 26, 0.08);
  }

  .dr-hero {
    position: relative;
    min-height: clamp(320px, 52vw, 420px);
    margin-top: 100px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dr-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .dr-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(45, 31, 26, 0.65), rgba(227, 104, 136, 0.45));
  }

  .dr-hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
    max-width: 820px;
    padding: 0 clamp(18px, 4vw, 44px);
  }

  .dr-label {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .dr-hero h1 {
    font-family: var(--doctors-font-display);
    font-size: clamp(2rem, 5.4vw, 3.2rem);
    line-height: 1.1;
    margin: 0 0 1rem;
  }

  .dr-hero p {
    color: rgba(255, 255, 255, 0.92);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0 auto;
    max-width: 640px;
  }

  .dr-search-wrap {
    max-width: 620px;
    margin: -1.5rem auto 2.7rem;
    position: relative;
    z-index: 2;
    padding: 0 clamp(18px, 4vw, 36px);
  }

  .dr-search-wrap input {
    width: 100%;
    padding: 1rem 1.25rem 1rem 3rem;
    border: 2px solid rgba(45, 31, 26, 0.1);
    border-radius: 16px;
    background: #fff;
    font-family: var(--doctors-font-body);
    font-size: 1rem;
    outline: none;
    box-shadow: 0 12px 36px rgba(45, 31, 26, 0.08);
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .dr-search-wrap input:focus {
    border-color: #e36888;
    box-shadow: 0 12px 36px rgba(227, 104, 136, 0.12);
  }

  .dr-search-wrap svg {
    position: absolute;
    left: clamp(32px, 6vw, 48px);
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    color: #8a7a72;
    pointer-events: none;
  }

  .dr-section {
    max-width: 1220px;
    margin: 0 auto 3.5rem;
    padding: 0 clamp(18px, 4vw, 36px);
  }

  .dr-section-title {
    font-family: var(--doctors-font-display);
    font-size: clamp(1.8rem, 3.6vw, 2.2rem);
    color: #2d1f1a;
    margin: 0 0 0.5rem;
  }

  .dr-section-sub {
    color: #6b5a52;
    font-size: 1rem;
    margin-bottom: 1.8rem;
  }

  .dr-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.25rem;
  }

  .dr-card {
    background: #fff;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(45, 31, 26, 0.06);
    transition: transform 0.35s, box-shadow 0.35s;
  }

  .dr-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 50px rgba(227, 104, 136, 0.12);
  }

  .dr-card-img {
    width: 100%;
    aspect-ratio: 3 / 3.5;
    object-fit: cover;
    object-position: top;
    background: #eee;
  }

  .dr-card-body {
    padding: 1.1rem 1.25rem 1.3rem;
  }

  .dr-card-name {
    font-family: var(--doctors-font-display);
    font-size: 1.12rem;
    color: #2d1f1a;
    margin: 0 0 0.2rem;
    line-height: 1.35;
  }

  .dr-card-spec {
    font-size: 0.88rem;
    color: #6b5a52;
    margin: 0 0 0.25rem;
  }

  .dr-card-degree {
    font-size: 0.82rem;
    color: #8a7a72;
    font-style: italic;
    line-height: 1.5;
    margin: 0;
  }

  .dr-card-schedule {
    margin-top: 0.8rem;
    font-size: 0.76rem;
    color: #2d1f1a;
    font-weight: 600;
    letter-spacing: 0.03em;
  }

  .dr-card-link {
    margin-top: 0.85rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #e36888;
    font-size: 0.87rem;
    font-weight: 600;
    transition: gap 0.25s;
  }

  .dr-card-link svg {
    width: 16px;
    height: 16px;
  }

  .dr-card-link:hover {
    gap: 0.7rem;
  }

  .dr-empty-state {
    max-width: 1220px;
    margin: 1rem auto 4rem;
    padding: 0 clamp(18px, 4vw, 36px);
    color: #6b5a52;
    font-size: 1rem;
    text-align: center;
  }

  @media (max-width: 700px) {
    .dr-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
    }

    .dr-card-body {
      padding: 1rem;
    }
  }

  @media (max-width: 520px) {
    .dr-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
