---
import MainLayout from '../layouts/MainLayout.astro';
import Navbar from '../components/Navbar.astro';
import { services } from '../data/siteContent';
---

<MainLayout title="Fertility Services | IVF, IUI, Testing & Gynecology in Delhi">
  <Navbar />
  <main>
    <section class="page-hero">
      <div class="page-hero-inner">
        <span class="section-tag">Our Services</span>
        <h1>Comprehensive <em>Fertility & Women’s</em> Care</h1>
        <p>
          Explore IVF, IUI, diagnostics, high-risk pregnancy care, and gynecology services designed around your clinical profile and long-term health goals.
        </p>
      </div>
    </section>

    <section class="services-page" id="services">
      <div class="services-inner">
        <div class="services-grid">
          {services.map((service) => (
            <article class="service-card" id={service.id}>
              <img src={`/images/services/${service.id}.svg`} alt={service.imageAlt} />
              <div class="service-content">
                <div class="service-icon"><i class={`fa-solid ${service.icon}`}></i></div>
                <h2>{service.title}</h2>
                <p>{service.desc}</p>
                <a href="/contact#contact-form" class="btn-rose">Book Consultation</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .page-hero {
    padding: 150px clamp(20px, 5vw, 60px) 70px;
    background: linear-gradient(150deg, var(--champagne-light) 0%, var(--cream) 70%, var(--blush) 100%);
  }

  .page-hero-inner {
    max-width: 980px;
    margin: 0 auto;
    text-align: center;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5vw, 4.4rem);
    font-weight: 300;
    line-height: 1.1;
    color: var(--midnight);
  }

  h1 em {
    font-style: italic;
    color: var(--rose-gold);
  }

  .page-hero p {
    margin: 16px auto 0;
    max-width: 760px;
    font-size: 1rem;
    color: var(--charcoal);
    font-weight: 300;
  }

  .services-page {
    padding: var(--section-pad);
    background: var(--cream);
  }

  .services-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .service-card {
    background: white;
    border-radius: 22px;
    overflow: hidden;
    box-shadow: var(--shadow-soft);
  }

  .service-card img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .service-content {
    padding: 24px;
  }

  .service-icon {
    width: 50px;
    height: 50px;
    border-radius: 14px;
    background: rgba(232, 76, 138, 0.14);
    color: var(--rose-gold);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
  }

  .service-content h2 {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 400;
    margin-bottom: 10px;
    color: var(--midnight);
  }

  .service-content p {
    color: var(--charcoal);
    font-size: 0.95rem;
    margin-bottom: 18px;
  }

  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

