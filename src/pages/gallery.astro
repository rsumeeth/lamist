---
import MainLayout from '../layouts/MainLayout.astro';
import HeroNav from '../components/HeroNav.astro';
import { galleryFilters, galleryHero, galleryItems, galleryMeta } from '../data/galleryContent';
---

<MainLayout
  title={galleryMeta.title}
  description={galleryMeta.description}
  canonical={galleryMeta.canonical}
  ogImage={galleryMeta.ogImage}
  showFooter={false}
  showConversionAssist={false}
>
  <div class="gallery-page">
    <HeroNav theme="about" />

    <main>
      <section class="gal-hero">
        <img class="gal-hero-bg" src={galleryHero.image} alt="Femme Nest Hospital facility" />
        <div class="gal-hero-content">
          <span class="gal-label">{galleryHero.label}</span>
          <h1>{galleryHero.title}</h1>
          <p>{galleryHero.description}</p>
        </div>
      </section>

      <div class="gal-filters" id="galFilters">
        {galleryFilters.map((filter, index) => (
          <button
            class:list={['gal-filter-btn', index === 0 && 'active']}
            data-filter={filter.id}
            type="button"
          >
            {filter.label}
          </button>
        ))}
      </div>

      <div class="gal-grid" id="galGrid">
        {galleryItems.map((item) => (
          <img
            class="gal-item"
            data-cat={item.category}
            src={item.image}
            alt={item.alt}
            loading="lazy"
          />
        ))}
      </div>

      <div class="gal-lightbox" id="galLB" aria-hidden="true">
        <button class="gal-lb-close" id="galLBClose" type="button" aria-label="Close gallery image">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        <button class="gal-lb-arrow gal-lb-prev" id="galLBPrev" type="button" aria-label="Previous image">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <img id="galLBImg" src="" alt="Gallery image preview" />
        <button class="gal-lb-arrow gal-lb-next" id="galLBNext" type="button" aria-label="Next image">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    </main>

    <footer class="ex-foot">&copy; Femme Nest Hospital &middot; Boutique Hospital for Women &amp; Child Care</footer>
  </div>
</MainLayout>

<script>
  const filterButtons = Array.from(document.querySelectorAll('.gal-filter-btn'));
  const allItems = Array.from(document.querySelectorAll('.gal-item'));
  const lightbox = document.getElementById('galLB');
  const lightboxImage = document.getElementById('galLBImg');
  const closeButton = document.getElementById('galLBClose');
  const prevButton = document.getElementById('galLBPrev');
  const nextButton = document.getElementById('galLBNext');

  let visibleItems = [...allItems];
  let lightboxIndex = 0;

  const applyFilter = (category) => {
    filterButtons.forEach((button) => {
      button.classList.toggle('active', button.dataset.filter === category);
    });

    visibleItems = [];
    allItems.forEach((item) => {
      const show = category === 'all' || item.dataset.cat === category;
      item.classList.toggle('hidden', !show);
      if (show) visibleItems.push(item);
    });
  };

  const openLightbox = (index) => {
    if (!lightbox || !lightboxImage || visibleItems.length === 0) return;
    lightboxIndex = index;
    lightboxImage.src = visibleItems[lightboxIndex].src;
    lightboxImage.alt = visibleItems[lightboxIndex].alt;
    lightbox.classList.add('active');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = () => {
    if (!lightbox) return;
    lightbox.classList.remove('active');
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  };

  const navigateLightbox = (direction) => {
    if (!lightboxImage || visibleItems.length === 0) return;
    lightboxIndex = (lightboxIndex + direction + visibleItems.length) % visibleItems.length;
    lightboxImage.src = visibleItems[lightboxIndex].src;
    lightboxImage.alt = visibleItems[lightboxIndex].alt;
  };

  filterButtons.forEach((button) => {
    button.addEventListener('click', () => applyFilter(button.dataset.filter || 'all'));
  });

  allItems.forEach((item) => {
    item.addEventListener('click', () => {
      const currentVisibleIndex = visibleItems.indexOf(item);
      if (currentVisibleIndex >= 0) {
        openLightbox(currentVisibleIndex);
      }
    });
  });

  closeButton?.addEventListener('click', closeLightbox);
  prevButton?.addEventListener('click', () => navigateLightbox(-1));
  nextButton?.addEventListener('click', () => navigateLightbox(1));

  lightbox?.addEventListener('click', (event) => {
    if (event.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (event) => {
    if (!lightbox?.classList.contains('active')) return;
    if (event.key === 'Escape') closeLightbox();
    if (event.key === 'ArrowLeft') navigateLightbox(-1);
    if (event.key === 'ArrowRight') navigateLightbox(1);
  });

  applyFilter('all');
</script>

<style is:global>
  .gallery-page {
    --gal-font-display: 'Playfair Display', serif;
    --gal-font-body: 'Inter', sans-serif;
    background: #fdf8f4;
    font-family: var(--gal-font-body);
  }

  .gallery-page .ex-foot {
    text-align: center;
    padding: 2rem;
    color: #6b5a54;
    font-size: 0.9rem;
    border-top: 1px solid rgba(45, 31, 26, 0.08);
  }

  .gal-hero {
    position: relative;
    min-height: clamp(320px, 52vw, 420px);
    margin-top: 100px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gal-hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gal-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(45, 31, 26, 0.65), rgba(227, 104, 136, 0.45));
  }

  .gal-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    max-width: 820px;
    padding: 0 clamp(18px, 4vw, 44px);
  }

  .gal-label {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .gal-hero h1 {
    font-family: var(--gal-font-display);
    font-size: clamp(2rem, 5.4vw, 3.2rem);
    line-height: 1.1;
    margin: 0 0 1rem;
  }

  .gal-hero p {
    color: rgba(255, 255, 255, 0.92);
    font-size: 1.05rem;
    line-height: 1.7;
    margin: 0 auto;
    max-width: 640px;
  }

  .gal-filters {
    max-width: 1200px;
    margin: 2.5rem auto 0;
    padding: 0 clamp(18px, 4vw, 36px);
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }

  .gal-filter-btn {
    padding: 0.55rem 1.4rem;
    border: 2px solid rgba(45, 31, 26, 0.12);
    border-radius: 999px;
    background: #fff;
    cursor: pointer;
    font-size: 0.88rem;
    font-weight: 600;
    color: #2d1f1a;
    transition: all 0.3s;
  }

  .gal-filter-btn:hover {
    border-color: #e36888;
    color: #e36888;
  }

  .gal-filter-btn.active {
    background: linear-gradient(135deg, #e36888, #f08c21);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 6px 20px rgba(227, 104, 136, 0.3);
  }

  .gal-grid {
    max-width: 1200px;
    margin: 2rem auto 5rem;
    padding: 0 clamp(18px, 4vw, 36px);
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .gal-item {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 20px;
    background: #eee;
    box-shadow: 0 10px 30px rgba(45, 31, 26, 0.08);
    transition: transform 0.4s, box-shadow 0.4s;
    cursor: pointer;
  }

  .gal-item:hover {
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 20px 50px rgba(227, 104, 136, 0.15);
  }

  .gal-item.hidden {
    display: none;
  }

  .gal-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1400;
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(8px);
    display: none;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .gal-lightbox.active {
    display: flex;
    opacity: 1;
  }

  .gal-lightbox img {
    max-width: 90vw;
    max-height: 85vh;
    border-radius: 16px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
  }

  .gal-lb-close,
  .gal-lb-arrow {
    position: absolute;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.25s;
  }

  .gal-lb-close:hover,
  .gal-lb-arrow:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .gal-lb-close {
    top: 1.5rem;
    right: 1.5rem;
  }

  .gal-lb-arrow {
    top: 50%;
    transform: translateY(-50%);
  }

  .gal-lb-prev {
    left: 1.5rem;
  }

  .gal-lb-next {
    right: 1.5rem;
  }

  .gal-lb-close svg,
  .gal-lb-arrow svg {
    width: 24px;
    height: 24px;
    stroke: #fff;
  }

  @media (max-width: 700px) {
    .gal-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.75rem;
      padding: 0 1rem;
    }
  }

  @media (max-width: 520px) {
    .gal-grid {
      grid-template-columns: 1fr;
    }

    .gal-lb-prev {
      left: 0.75rem;
    }

    .gal-lb-next {
      right: 0.75rem;
    }
  }
</style>
