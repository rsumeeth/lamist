function getAstroScopeAttr(el: Element | null): string {
  if (!el) return '';
  const attr = Array.from(el.attributes).find((a: Attr) => a.name.startsWith('data-astro-cid-'));
  return attr ? attr.name : '';
}
function applyAstroScope(node: Element | null, scopeAttr: string): void {
  if (!scopeAttr || !node) return;
  (node as HTMLElement).setAttribute(scopeAttr, '');
  node.querySelectorAll('*').forEach((child: Element) => (child as HTMLElement).setAttribute(scopeAttr, ''));
}
function htmlToNode(html: string): HTMLElement {
  const template = document.createElement('template');
  template.innerHTML = html.trim();
  return template.content.firstElementChild as HTMLElement;
