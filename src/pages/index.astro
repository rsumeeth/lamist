// Carousel arrow controls â€” smoothly tween the underlying CSS animation's currentTime
(function(){
  const targets = {
    doctors: { el: document.querySelector('.doctors-grid'), step: 6000, tweening: false },
    testimonials: { el: document.querySelector('.testimonials-grid'), step: 7000, tweening: false }
  };
  const TWEEN_MS = 650;
  // easeInOutCubic â€” smooth acceleration and deceleration
  const ease = (x: number): number => x < 0.5 ? 4 * x * x * x : 1 - Math.pow(-2 * x + 2, 3) / 2;

  function tween(t: any, dir: any) {
    const anims = t.el.getAnimations ? t.el.getAnimations() : [];
    if (!anims.length) {
      t.el.parentElement.scrollBy({ left: dir * 320, behavior: 'smooth' });
      return;
    }
    const a = anims[0];
    const dur = (a.effect && a.effect.getTiming().duration) || 60000;
    const startCT = Number(a.currentTime) || 0;
    const delta = dir * t.step;
    // Pause the running infinite loop during the manual tween so motion is clean
    const wasPlaying = a.playState === 'running';
    if (wasPlaying) a.pause();
    const startWall = performance.now();
    t.tweening = true;

    function frame(now: number) {
      const p = Math.min(1, (now - startWall) / TWEEN_MS);
      const eased = ease(p);
      let ct = startCT + delta * eased;
      // wrap within [0, dur)
      ct = ((ct % dur) + dur) % dur;
      a.currentTime = ct;
      if (p < 1) {
        requestAnimationFrame(frame);
      } else {
        t.tweening = false;
        if (wasPlaying) a.play();
      }
    }
    requestAnimationFrame(frame);
  }

  document.querySelectorAll('.scroll-arrow').forEach(btn => {
    const btnEl = btn as HTMLElement;
    btnEl.addEventListener('click', () => {
      const key = btnEl.dataset.carousel;
      const dir = parseInt(btnEl.dataset.dir || '1', 10);
      const t = targets[key as keyof typeof targets];
      if (!t || !t.el || t.tweening) return;
      tween(t, dir);
    });
  });
})();

// Gallery slider
let galIdx = 0;
const galSlider = document.getElementById('wcuSlider');
const galCounter = document.getElementById('galCounter');
const galImages = galSlider ? galSlider.querySelectorAll('img') : null;

const galSlide = (dir: number) => {
  if (!galCounter || !galImages || galImages.length === 0) return;
  galImages[galIdx].classList.remove('gal-active');
  galIdx = (galIdx + dir + galImages.length) % galImages.length;
  galImages[galIdx].classList.add('gal-active');
  galCounter.textContent = `${galIdx + 1} / ${galImages.length}`;
};

// Inline onclick handlers require a global function in Astro's module-scoped scripts.
(window as typeof window & { galSlide: (dir: number) => void }).galSlide = galSlide;

// Smooth scroll for anchor links
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    e.preventDefault();
    const href = a.getAttribute('href');
    if (!href) return;
    const target = document.querySelector(href);
    if (target) (target as HTMLElement).scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
});
