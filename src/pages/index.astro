  if (d.img) return `<img src="${d.img}" alt="${d.name}">`;
  // Demo placeholder via ui-avatars â€” elegant initials on brand gradient
  const name = encodeURIComponent(d.name.replace('Dr. ', ''));
  const colors = ['E36888', 'F08C21', '6698CC', 'B4B534'];
  const bg = colors[Math.abs(d.name.length) % colors.length];
  return `<img src="https://ui-avatars.com/api/?name=${name}&background=${bg}&color=ffffff&size=340&bold=true&font-size=0.38&format=png" alt="${d.name}">`;
}
function doctorCard(d: any, idx: number, hidden: boolean = false): string {
  return `<div class="doctor-card"${hidden ? ' aria-hidden="true"' : ''}>
    <div class="doctor-avatar">${doctorImg(d)}<div class="doctor-ring"></div></div>
    <div class="doctor-name">${d.name}</div>
    <div class="doctor-spec">${d.spec}</div>
    <div class="doctor-stars">${star.repeat(5)}</div>
    <div class="doctor-timing">${d.opd}</div>
    <a href="/doctors/${d.slug}" class="doctor-learn-more">Learn More <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
  </div>`;
}
const grid = document.getElementById('doctorsGrid');
if (grid) {
  const scopeAttr = getAstroScopeAttr(grid);
  const cardsHtml = doctors.map((d, i) => doctorCard(d, i)).concat(doctors.map((d, i) => doctorCard(d, i, true)));
  if (scopeAttr) {
    const fragment = document.createDocumentFragment();
    cardsHtml.forEach((html) => {
      const node = htmlToNode(html);
      if (node) {
        applyAstroScope(node, scopeAttr);
        fragment.appendChild(node);
      }
    });
    grid.replaceChildren(fragment);
  } else {
    grid.innerHTML = cardsHtml.join('');
  }
}

