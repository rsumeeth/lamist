  .hero-arrow--next { right: 1rem; }
}
@media (max-width: 768px) {
  html { font-size: 16px; }
  .nav { padding: 0.75rem 1.25rem; min-height: 72px; gap: 1rem; }
  .nav.scrolled { padding: 0.65rem 1.25rem; min-height: 66px; }
  .nav-logo-img { height: 50px; }
  .nav.scrolled .nav-logo-img { height: 50px; }
  .nav.hero-nav .nav-logo-img { height: 50px; }
  .section { padding: 3rem 1.2rem; }
  .hero { min-height: 600px; height: auto; }
  .hero-slide { padding-top: 80px; }
  .hero-overlay { padding: 0 1.5rem; max-width: 100%; }
  .hero-tagline { font-size: clamp(2.6rem, 10vw, 3.6rem); margin-bottom: 1rem; }
  .hero-subtitle { font-size: 1rem; }
  .hero-cta-row { flex-wrap: wrap; gap: 0.75rem; }
  .about-grid { grid-template-columns: 1fr; }
  .about-image-main { height: 320px; }
  .specialties-grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
  .why-grid { grid-template-columns: 1fr 1fr; gap: 1rem; }
  .doctor-card { width: 240px; padding: 1.5rem 1rem; }
  .doctor-avatar { width: 140px; height: 140px; }
  .testimonial-card { width: 270px; padding: 0 0 1.4rem; }
  .facilities-grid { grid-template-columns: 1fr; grid-template-rows: auto; gap: 1rem; }
  .facility-card:nth-child(1) { grid-column: auto; }
  .facilities-grid .facility-card { height: 240px; }
  .contact-grid { grid-template-columns: 1fr; gap: 1.5rem; }
  .contact-info-gradient { padding: 2rem 1.5rem; }
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
  .progress-row { grid-template-columns: 1fr; max-width: 300px; }
  .donut-container { flex-direction: column; }
  .form-row { grid-template-columns: 1fr; }
  .footer-bottom { flex-direction: column; gap: 1rem; text-align: center; }
  .stats-row { grid-template-columns: 1fr 1fr; gap: 1rem; }
  .quick-contacts { flex-wrap: wrap; }
  .section-title { font-size: clamp(2rem, 7vw, 2.6rem); }
  h2 { font-size: clamp(1.8rem, 6vw, 2.4rem); }
}
@media (max-width: 480px) {
  html { font-size: 15px; }
  .nav { padding: 0.65rem 1rem; min-height: 66px; }
  .nav-logo-img { height: 44px; }
  .nav.scrolled .nav-logo-img { height: 44px; }
  .nav.hero-nav .nav-logo-img { height: 44px; }
  .hero { min-height: 560px; }
  .hero-slide { padding-top: 74px; }
  .hero-overlay { padding: 0 1.25rem; }
  .hero-tagline { font-size: clamp(2.2rem, 11vw, 2.9rem); line-height: 1.05; }
  .hero-arrow { width: 34px; height: 34px; }
  .hero-arrow--prev { left: 0.6rem; }
  .hero-arrow--next { right: 0.6rem; }
  .hero-arrow svg { width: 18px; height: 18px; }
  .hero-slider-nav { bottom: 1.5rem; }
