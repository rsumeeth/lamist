/*   
   HERO â€” FULL SCREEN IMMERSIVE IMAGE
      */
.hero {
  position: relative;
  width: 100%;
  height: 100vh;
  min-height: 720px;
  overflow: hidden;
}
/* Slider slides â€” smooth slide left */
.hero-slide {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-top: 110px;
  transform: translateX(100%);
  z-index: 0;
  pointer-events: none;
  will-change: transform;
}
.hero-slide--active {
  transform: translateX(0);
  z-index: 2;
  pointer-events: auto;
}
.hero-slide--exit {
  transform: translateX(-100%);
  z-index: 1;
}
.hero-slide.sliding {
  transition: transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.hero-bg {
  position: absolute;
  inset: 0;
  z-index: 0;
  background: #2d1f1a;
}
.hero-bg img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: right 25%;
}
.hero-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(30,20,15,0.5) 0%, rgba(30,20,15,0.2) 35%, rgba(30,20,15,0.15) 55%, rgba(30,20,15,0.75) 100%),
    linear-gradient(90deg, rgba(30,20,15,0.7) 0%, rgba(30,20,15,0.35) 35%, transparent 60%);
}
.hero-overlay {
  position: relative;
  z-index: 2;
  padding: 0 4rem;
  max-width: 780px;
}
