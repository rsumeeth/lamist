<script>
// â”€â”€ Hero Slider
(function(){
  const heroRoot = document.querySelector('.hero') as HTMLElement | null;
  if (!heroRoot || heroRoot.dataset.heroSliderInit === 'true') return;
  heroRoot.dataset.heroSliderInit = 'true';

  const slides = Array.from(document.querySelectorAll('.hero-slide')) as HTMLElement[];
  const dots = Array.from(document.querySelectorAll('.hero-dot')) as HTMLElement[];
  const prevBtn = document.querySelector('.hero-arrow--prev') as HTMLElement | null;
  const nextBtn = document.querySelector('.hero-arrow--next') as HTMLElement | null;
  const total = slides.length;
  if (total === 0) return;

  let current = 0;
  let timer: ReturnType<typeof setInterval> | undefined;
  let sliding = false;
  const AUTO_MS = 6500;

  function setActiveDot(index: number){
    dots.forEach((dot, i) => dot.classList.toggle('hero-dot--active', i === index));
  }

  function startTimer(){
    if (total <= 1) return;
    if (timer) clearInterval(timer);
    timer = setInterval(() => goTo(current + 1), AUTO_MS);
  }

  function resetTimer(){
    if (timer) clearInterval(timer);
    startTimer();
  }

  function goTo(n: number){
    n = (n + total) % total;
    if(n === current || sliding) return;
    sliding = true;
    const prev = current;
    current = n;

    // Position new slide off-screen right, no transition
    const currentSlide = slides[current];
    const prevSlide = slides[prev];
    currentSlide.classList.remove('hero-slide--exit','sliding');
    currentSlide.style.transform = 'translateX(100%)';
    void currentSlide.offsetWidth; // single reflow

    // Add transition class to both, then animate
    prevSlide.classList.add('sliding');
    currentSlide.classList.add('sliding');

    // Animate: old â†’ left, new â†’ center
    prevSlide.classList.remove('hero-slide--active');
    prevSlide.classList.add('hero-slide--exit');
    currentSlide.style.transform = '';
    currentSlide.classList.add('hero-slide--active');

    setActiveDot(current);

    // Cleanup after transition ends
    setTimeout(function(){
      prevSlide.classList.remove('hero-slide--exit','sliding');
      currentSlide.classList.remove('sliding');
      sliding = false;
    }, 1050);
    resetTimer();
  }

  if (prevBtn) prevBtn.addEventListener('click', () => goTo(current - 1));
  if (nextBtn) nextBtn.addEventListener('click', () => goTo(current + 1));
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const target = parseInt(dot.dataset.goto || '-1', 10);
      if (!Number.isNaN(target) && target >= 0 && target < total) goTo(target);
    });
  });

  setActiveDot(current);
  startTimer();
})();

// Mobile menu
const mobileToggle = document.getElementById('mobileToggle') as HTMLElement;
const mobileMenu = document.getElementById('mobileMenu') as HTMLElement;
const mobileOverlay = document.getElementById('mobileOverlay') as HTMLElement;
const mobileClose = document.getElementById('mobileClose') as HTMLElement;
function openMobile() { mobileMenu.classList.add('active'); mobileOverlay.classList.add('active'); document.body.style.overflow='hidden'; }
function closeMobile() { mobileMenu.classList.remove('active'); mobileOverlay.classList.remove('active'); document.body.style.overflow=''; }
mobileToggle.addEventListener('click', openMobile);
mobileClose.addEventListener('click', closeMobile);
