---
import MainLayout from '../../layouts/MainLayout.astro';
import HeroNav from '../../components/HeroNav.astro';
import {
  vaccinationChecklist,
  vaccinationDetailSection,
  vaccinationHighlights,
  vaccinationIntro,
  vaccinationPackageContactNumbers,
  vaccinationPackageHero,
  vaccinationPackageMeta,
  vaccinationPackageNote,
  vaccinationPackagePricing,
  vaccinationScheduleRows,
} from '../../data/vaccinationPackageContent';

const toTel = (value: string) => `tel:+${value.replace(/\D/g, '')}`;
const formatInr = (value: string) => {
  const digitsOnly = value.replace(/\D/g, '');
  if (!digitsOnly) return value;
  return new Intl.NumberFormat('en-IN', {
    style: 'currency',
    currency: 'INR',
    maximumFractionDigits: 0,
  }).format(Number(digitsOnly));
};
---

<MainLayout
  title={vaccinationPackageMeta.title}
  description={vaccinationPackageMeta.description}
  canonical={vaccinationPackageMeta.canonical}
  ogImage={vaccinationPackageMeta.ogImage}
  showFooter={false}
  showConversionAssist={false}
>
  <div class="vac-page">
    <HeroNav theme="about" />

    <main>
      <section class="vac-hero">
        <img src={vaccinationPackageHero.image} alt="Vaccination support at Femme Nest Hospital" loading="eager" decoding="async" />
        <div class="vac-hero-content">
          <span class="vac-label">{vaccinationPackageHero.label}</span>
          <h1>{vaccinationPackageHero.title}</h1>
          <p>{vaccinationPackageHero.subtitle}</p>
        </div>
      </section>

      <section class="vac-body">
        <p class="vac-intro">{vaccinationIntro}</p>

        <div class="vac-highlights">
          {vaccinationHighlights.map((item) => (
            <article class="vac-feature">
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>

        <div class="vac-media">
          <img src={vaccinationDetailSection.image} alt={vaccinationDetailSection.imageAlt} loading="lazy" decoding="async" />
          <p>{vaccinationDetailSection.imageCaption}</p>
        </div>

        <section class="vac-detail">
          <h2>{vaccinationDetailSection.title}</h2>
          {vaccinationDetailSection.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
          <ul>
            {vaccinationChecklist.map((line) => (
              <li>{line}</li>
            ))}
          </ul>
        </section>

        <section class="vac-series">
          <h2>Total Care Series</h2>
          <div class="vac-table-shell">
            <table>
              <thead>
                <tr>
                  <th>Months</th>
                  <th>Vaccine</th>
                </tr>
              </thead>
              <tbody>
                {vaccinationScheduleRows.map((row) => (
                  <tr>
                    <td>{row.month}</td>
                    <td>{row.vaccines}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="vac-note">{vaccinationPackageNote}</p>
        </section>

        <section class="vac-pricing">
          <h2>Package Pricing</h2>
          <div class="vac-pricing-grid">
            <article class="vac-price-card vac-price-muted">
              <h3>Package Price</h3>
              <p class="vac-price-strike">{formatInr(vaccinationPackagePricing.packagePrice)}</p>
            </article>
            <article class="vac-price-card">
              <h3>Our Price</h3>
              <p>{formatInr(vaccinationPackagePricing.ourPrice)}</p>
            </article>
          </div>
        </section>

        <section class="vac-cta">
          <h2>Book Vaccination Package Appointment</h2>
          <p>For appointments, call:</p>
          <div class="vac-call-links">
            {vaccinationPackageContactNumbers.map((number) => (
              <a href={toTel(number)}>{number}</a>
            ))}
          </div>
        </section>
      </section>
    </main>

    <footer class="ex-foot">&copy; Femme Nest Hospital &middot; Boutique Hospital for Women &amp; Child Care</footer>
  </div>
</MainLayout>

<style is:global>
  .vac-page {
    --vac-font-display: 'Playfair Display', serif;
    --vac-font-body: 'Inter', sans-serif;
    background: #fdf8f4;
    font-family: var(--vac-font-body);
  }

  .vac-hero {
    position: relative;
    height: 420px;
    overflow: hidden;
    margin-top: 100px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vac-hero img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .vac-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(45, 31, 26, 0.64), rgba(227, 104, 136, 0.45));
  }

  .vac-hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: #fff;
    max-width: 860px;
    padding: 0 2rem;
  }

  .vac-label {
    display: inline-block;
    padding: 0.4rem 1rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.15);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  .vac-hero h1 {
    font-family: var(--vac-font-display);
    font-size: clamp(2.2rem, 5.2vw, 3.5rem);
    margin: 0;
    line-height: 1.1;
  }

  .vac-hero p {
    margin: 0.9rem auto 0;
    max-width: 620px;
    font-size: 1.08rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.93);
  }

  .vac-body {
    max-width: 1220px;
    margin: 0 auto;
    padding: clamp(28px, 4vw, 54px) clamp(18px, 4vw, 36px) clamp(34px, 5vw, 60px);
  }

  .vac-intro {
    text-align: center;
    max-width: 940px;
    margin: 0 auto;
    font-size: 1.06rem;
    color: #4a3832;
    line-height: 1.75;
  }

  .vac-highlights {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .vac-feature {
    background: #fff;
    border-radius: 18px;
    padding: 1.2rem 1.2rem 1.35rem;
    border: 1px solid rgba(45, 31, 26, 0.08);
    box-shadow: 0 12px 34px rgba(45, 31, 26, 0.05);
  }

  .vac-feature h3 {
    margin: 0;
    font-size: 1.1rem;
    color: #2d1f1a;
    font-family: var(--vac-font-display);
  }

  .vac-feature p {
    margin: 0.55rem 0 0;
    color: #6b5a52;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .vac-media {
    margin-top: 1.9rem;
    border-radius: 22px;
    overflow: hidden;
    background: #fff;
    border: 1px solid rgba(45, 31, 26, 0.08);
    box-shadow: 0 16px 44px rgba(45, 31, 26, 0.08);
  }

  .vac-media img {
    width: 100%;
    height: auto;
    display: block;
  }

  .vac-media p {
    margin: 0;
    padding: 0.95rem 1.1rem;
    color: #6b5a52;
    font-size: 0.95rem;
    text-align: center;
  }

  .vac-detail {
    margin-top: 1.8rem;
    background: #fff;
    border-radius: 22px;
    padding: clamp(20px, 3vw, 30px);
    box-shadow: 0 14px 40px rgba(45, 31, 26, 0.06);
  }

  .vac-detail h2,
  .vac-series h2,
  .vac-pricing h2,
  .vac-cta h2 {
    font-family: var(--vac-font-display);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: #2d1f1a;
    margin: 0 0 0.8rem;
    text-align: center;
  }

  .vac-detail p {
    color: #4a3832;
    line-height: 1.75;
    margin: 0.65rem 0 0;
    text-align: center;
  }

  .vac-detail ul {
    margin: 1rem 0 0;
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem 1rem;
  }

  .vac-detail li {
    padding-left: 1.15rem;
    position: relative;
    color: #4a3832;
    line-height: 1.5;
  }

  .vac-detail li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62rem;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(135deg, #e36888, #f08c21);
  }

  .vac-series {
    margin-top: 1.8rem;
  }

  .vac-table-shell {
    background: #fff;
    border-radius: 20px;
    overflow: auto;
    box-shadow: 0 16px 46px rgba(45, 31, 26, 0.07);
    border: 1px solid rgba(240, 140, 33, 0.2);
  }

  .vac-series table {
    width: 100%;
    min-width: 660px;
    border-collapse: collapse;
  }

  .vac-series thead th {
    background: #ef7469;
    color: #fff;
    font-size: 1rem;
    text-align: left;
    padding: 0.92rem 1rem;
  }

  .vac-series thead th:first-child,
  .vac-series tbody td:first-child {
    width: 120px;
    text-align: center;
  }

  .vac-series tbody td {
    border-top: 1px solid rgba(45, 31, 26, 0.12);
    padding: 0.9rem 1rem;
    color: #2d1f1a;
    font-size: 1rem;
    line-height: 1.55;
    vertical-align: top;
  }

  .vac-note {
    text-align: center;
    color: #4a3832;
    margin: 1rem auto 0;
    max-width: 920px;
    font-size: 1.03rem;
  }

  .vac-pricing {
    margin-top: 1.9rem;
  }

  .vac-pricing-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.95rem;
    margin-top: 1rem;
  }

  .vac-price-card {
    background: #fff;
    border: 1px solid rgba(227, 104, 136, 0.22);
    border-radius: 16px;
    padding: 1rem 1.1rem;
    text-align: center;
  }

  .vac-price-card h3 {
    margin: 0;
    color: #8b6f65;
    font-size: 1rem;
  }

  .vac-price-card p {
    margin: 0.45rem 0 0;
    color: #e36888;
    font-weight: 800;
    font-size: clamp(1.8rem, 4vw, 2.35rem);
    line-height: 1;
  }

  .vac-price-muted {
    border-style: dashed;
    border-color: rgba(45, 31, 26, 0.26);
  }

  .vac-price-muted p {
    color: #7b6b64;
  }

  .vac-price-strike {
    text-decoration: line-through;
    text-decoration-thickness: 2px;
    text-decoration-color: #2d1f1a;
  }

  .vac-cta {
    margin-top: 1.85rem;
    text-align: center;
  }

  .vac-cta p {
    color: #6b5a52;
    margin: 0;
    font-size: 1rem;
  }

  .vac-call-links {
    margin-top: 0.85rem;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .vac-call-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.35rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #e36888, #f08c21);
    color: #fff;
    font-weight: 700;
    box-shadow: 0 8px 22px rgba(227, 104, 136, 0.28);
  }

  .vac-page .ex-foot {
    text-align: center;
    padding: 2rem;
    color: #6b5a54;
    font-size: 0.9rem;
    border-top: 1px solid rgba(45, 31, 26, 0.08);
  }

  @media (max-width: 980px) {
    .vac-highlights {
      grid-template-columns: 1fr;
    }

    .vac-detail ul {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .vac-hero {
      height: 350px;
    }

    .vac-pricing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
